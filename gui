	if orderTeleActive then
		orderPanel.Visible = true
		orderPanel.Size = UDim2.new(1, -24, 0, orderPanelH)
		orderPanel.Position = UDim2.new(0, 12, 0, 226 + shift)
		statusLabel.Position = UDim2.new(0, 14, 0, 226 + shift + orderPanelH + 6)
		lockBar.Position     = UDim2.new(0, 12, 0, 226 + shift + orderPanelH + 28)
