local LOCK_MIN, LOCK_MAX = 0.02, 1.0

local function sliderToWalk(t) return WALK_MIN + (WALK_MAX - WALK_MIN) * t end
local function walkToSlider(v) return (v - WALK_MIN) / (WALK_MAX - WALK_MIN) end
local function sliderToLock(t) return LOCK_MIN + (LOCK_MAX - LOCK_MIN) * t end
local function lockToSlider(v) return (v - LOCK_MIN) / (LOCK_MAX - LOCK_MIN) end

local function fmtTime(s)
	return s < 1 and string.format("%.2fs", s) or string.format("%.1fs", s)
end

