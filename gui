local function searchWorkspace(query)
	local results = {}
	query = query:lower()
	
	local descendants = workspace:GetDescendants()
	for i = 1, #descendants do
		local child = descendants[i]
		if (child:IsA("BasePart") or child:IsA("Model")) and child.Name:lower():find(query, 1, true) then
			table.insert(results, {
				object = child, 
				path = "Workspace/" .. child:GetFullName(), 
				className = child.ClassName
			})
		end
	end
	return results
end

